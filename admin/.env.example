# Use MSW handlers (default) or hit the real backend.
# Set to "false" to disable MSW and hit the real API.
VITE_USE_MSW=true

# API base URL. Empty = use window.location.origin (works with MSW and same-origin dev).
# Set to "http://localhost:3000" to hit the real backend from a different origin.
VITE_API_URL=

# Admin bearer token for write operations against real backend.
VITE_ADMIN_TOKEN=dev-admin-token
