    <pubDate>2023-01-16 11:00:00</pubDate>
    <dc:creator>admin</dc:creator>
    <content:encoded><![CDATA[This is a draft]]></content:encoded>
    <excerpt:encoded><![CDATA[]]></excerpt:encoded>
  </item>

  <item>
    <wp:post_id>12</wp:post_id>
