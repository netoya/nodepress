{
  "name": "nodepress",
  "version": "0.1.0",
  "private": true,
  "description": "WordPress-compatible CMS built on Node.js and TypeScript",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.8.0",
  "workspaces": [
    "packages/*",
    "admin"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/server",
    "dev:admin": "npm run dev --workspace=admin",
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --build",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:seed": "npm run seed --workspace=packages/db",
    "db:reset": "npm run reset --workspace=packages/db",
    "db:drizzle:generate": "npm run drizzle:generate --workspace=packages/db",
    "db:drizzle:push": "npm run drizzle:push --workspace=packages/db",
    "db:drizzle:status": "npm run drizzle:status --workspace=packages/db",
    "cli": "npm run start --workspace=packages/cli --",
    "spike:phpwasm": "npm run dev --workspace=packages/spike-phpwasm",
    "test:coverage": "vitest run --coverage",
    "test:integration": "DOCKER_AVAILABLE=true vitest run --root packages/server --config vitest.integration.config.ts && DOCKER_AVAILABLE=true vitest run --root packages/db --config vitest.integration.config.ts",
    "smoke:fresh-clone": "tsx scripts/smoke-fresh-clone.ts",
    "prepare": "husky",
    "demo:reset": "npm run db:reset",
    "demo:video": "cd admin && npx playwright test --config=playwright.demo.config.ts"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "^3.3.0",
    "testcontainers": "^11.14.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "8.58.2",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,yaml,yml,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "tar": "^7.5.13"
  }
}
