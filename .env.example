DATABASE_URL=postgresql://nodepress:nodepress@localhost:5432/nodepress
REDIS_URL=redis://localhost:6379
NODE_ENV=development
PORT=3000
JWT_SECRET=change-me-in-production

# Admin Bearer token for simplified auth (sprint 1).
# In production, set a strong random secret.
# Default dev value: dev-admin-token (never use in production).
NODEPRESS_ADMIN_TOKEN=dev-admin-token
